<?xml version="1.0" encoding="UTF-8"?>
<meta-runner name="Download Sonar Automation JAR">
    <description>Downloads the ${name} JAR artifact from Maven repository into .${name}/</description>
    <settings>
        <build-runners>
            <runner name="Download ${name}" type="Maven2">
                <parameters>
                    <param name="goals" value="org.apache.maven.plugins:maven-dependency-plugin:3.1.2:copy"/>
                    <param name="jvmArgs" value="-Duser.home=%teamcity.agent.jvm.user.home%"/>
                    <param name="maven.path" value="%env.BUILD_ENV%/MAVEN/3.6.3"/>
                    <param name="runnerArgs">
                        <![CDATA[-B -Dartifact=${group}:${name}:${version}:jar -DoutputDirectory=.]]></param>
                    <param name="target.jdk.home" value="%env.JDK_21_0_x64%"/>
                    <param name="userSettingsSelection" value="userSettingsSelection:default"/>
                    <param name="teamcity.build.workingDir" value=".${name}"/>
                </parameters>
            </runner>
        </build-runners>
        <requirements />
    </settings>
</meta-runner>