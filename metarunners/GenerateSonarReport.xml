<?xml version="1.0" encoding="UTF-8"?>
<meta-runner name="Generate Sonar Report">
    <description>
        Generates a SAST HTML report from SonarQube analysis results.
        Depends on following TeamCity parameters:
        * SONAR_SERVER_URL
        * SONAR_PROJECT_KEY
        * SONAR_PROJECT_NAME
        * SONAR_SOURCE_BRANCH
        * SONAR_TARGET_BRANCH
        * SONAR_JDK_HOME
        * env.SONAR_USERNAME
        * env.SONAR_PASSWORD
    </description>
    <settings>
        <parameters>
            <param name="COMPONENT_NAME" value="%COMPONENT_NAME%" />
            <param name="COMPONENT_VERSION" value="%BUILD_VERSION%" />
            <param name="SONAR_PROJECT_KEY" value="%SONAR_PROJECT_KEY%" />
            <param name="SONAR_PROJECT_NAME" value="%SONAR_PROJECT_NAME%" />
            <param name="SONAR_SOURCE_BRANCH" value="%SONAR_SOURCE_BRANCH%" />
            <param name="SONAR_TARGET_BRANCH" value="%SONAR_TARGET_BRANCH%" />
        </parameters>
        <build-runners>
            <runner name="Download sonar-automation JAR" type="DownloadSonarAutomationJAR"/>
            <runner name="Generate Sonar Report" type="simpleRunner">
                <parameters>
                    <param name="script.content"><![CDATA[
"%SONAR_JDK_HOME%/bin/java" -jar "./.sonar-automation/sonar-automation-${version}.jar" generate-sonar-report --component-name "%COMPONENT_NAME%" --component-version "%COMPONENT_VERSION%" --sonar-project-key "%SONAR_PROJECT_KEY%" --sonar-project-name "%SONAR_PROJECT_NAME%" --sonar-source-branch "%SONAR_SOURCE_BRANCH%" --sonar-target-branch "%SONAR_TARGET_BRANCH%" --sonar-server-url "%SONAR_SERVER_URL%"
]]></param>
                    <param name="teamcity.step.mode" value="default"/>
                    <param name="use.custom.script" value="true"/>
                </parameters>
            </runner>
        </build-runners>
        <requirements />
    </settings>
</meta-runner>

